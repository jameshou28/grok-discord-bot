# Your Discord Bot Token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Your Google Gemini API Keys from https://aistudio.google.com/app/apikey
# You can provide multiple keys separated by commas. The bot will automatically rotate them!
GEMINI_API_KEYS=key1,key2,key3

# Hack Club AI fallback (used only when all Gemini keys are quota-exhausted)
# Get a key from https://ai.hackclub.com/dashboard
HACKCLUB_AI_KEY=your_hackclub_api_key_here
# Optional: override the fallback model (default: google/gemini-2.5-flash-lite)
# HACKCLUB_MODEL=google/gemini-2.5-flash-lite
